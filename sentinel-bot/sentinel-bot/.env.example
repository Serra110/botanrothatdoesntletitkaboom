# Discord bot token (Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application client ID (Developer Portal > General Information)
CLIENT_ID=

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sentinel

# Owner / Co-Owner Discord user IDs
OWNER_ID=
CO_OWNER_ID=

# Critical channel IDs (comma-separated, e.g. 123456789,987654321)
CRITICAL_CHANNELS=

# Admin role IDs to strip during emergency (comma-separated)
ADMIN_ROLES_TO_REMOVE=

# Trusted role IDs that are never affected by emergency/lockdown (comma-separated)
TRUSTED_ROLES=

# Channels to save chat messages from (comma-separated channel IDs, empty = none)
SAVE_CHANNELS=

# Channels to exclude from chat saving (comma-separated channel IDs)
EXCLUDE_CHANNELS=

# Chat save: local path for saving messages (e.g. ./chat-logs)
CHAT_SAVE_LOCAL_PATH=./chat-logs

# Environment
NODE_ENV=development
