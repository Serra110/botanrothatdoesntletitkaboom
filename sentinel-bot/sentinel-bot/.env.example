# Token do bot Discord (Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Client ID da aplicação (Developer Portal > General Information)
CLIENT_ID=

# String de ligação ao MongoDB (local ou Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sentinel

# IDs por defeito de Owner/Co-Owner (podem também ser definidos via /config por servidor)
DEFAULT_OWNER_ID=
DEFAULT_CO_OWNER_ID=

# Ambiente
NODE_ENV=development
